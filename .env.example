VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Carga masiva de usuarios: despliega la Edge Function admin-bulk-create-users
# (supabase functions deploy admin-bulk-create-users). Requiere SUPABASE_SERVICE_ROLE_KEY en secrets.
# Ejecuta también la migración 020_bulk_user_import.sql antes de usar el módulo.

# Recuperación de contraseña: en Supabase → Authentication → URL configuration,
# añade a Redirect URLs la URL absoluta de /auth/reset-password (p. ej. http://localhost:5173/auth/reset-password).
# Optional: show embedded demo block on player dashboard when not in a group
# VITE_DEMO_MODE=true
